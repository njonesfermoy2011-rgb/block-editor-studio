# Files and directories that must NOT ship to the WordPress.org SVN trunk.
# Everything not listed here is copied to trunk as-is.
/.git
/.github
/.gitignore
/.distignore
/.wordpress-org
/dist
/PLAN.md
/node_modules
/vendor
/_typos.toml
/composer.json
/composer.lock
/phpcs.xml
/phpcs.xml.dist
/phpstan.neon
/.php-cs-fixer.dist.php
/package.json
/package-lock.json
*.zip
*.log
.DS_Store
Thumbs.db
